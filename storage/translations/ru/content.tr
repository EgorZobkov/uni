  'tr_6f1d1801e7fd50410971cb5c1107225f' => 'Восстановить профиль не получится. Все ваши объявления, отзывы, заказы и диалоги будут потеряны.',
  'tr_8076b18350b9af68e86b8df4d46d3307' => 'Откройте свой онлайн-магазин с рекламными баннерами, удобными фильтрами, страницами и поиском по вашим товарам',
